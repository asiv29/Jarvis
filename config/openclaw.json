{
  "env": {
    "DEEPSEEK_API_KEY": "${DEEPSEEK_API_KEY}"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "deepseek/deepseek-chat",
        "reasoning": "deepseek/deepseek-reasoner"
      }
    }
  },
  "skills": {
    "paths": [
      "/home/node/.openclaw/skills"
    ]
  },
  "memory": {
    "enabled": true,
    "path": "/home/node/.openclaw/workspace/memory"
  },
  "context": {
    "bootstrap": [
      "SOUL.md",
      "IDENTITY.md",
      "AGENTS.md",
      "MEMORY.md"
    ]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "${TELEGRAM_BOT_TOKEN}"
    },
    "whatsapp": {
      "enabled": false
    }
  },
  "cron": {
    "enabled": true,
    "jobsPath": "/home/node/.openclaw/cron/jobs.json"
  }
}
