# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Messaging channels — fill in whichever you use
# Telegram: get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# WhatsApp: set to true to enable QR-code pairing on first start
WHATSAPP_ENABLED=false

# Optional: Google Calendar (OAuth — leave blank to skip)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Timezone — used for cron scheduling
TZ=Australia/Melbourne
